# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Copie este arquivo para `.env` apenas no ambiente local.
# Em homologacao e producao, configure estas variaveis fora do Git
# (servidor, container, pipeline ou painel de secrets).

# Secret JWT    https://www.md5hashgenerator.com/
JWT_SECRET=

# Provider padrao do projeto:
DATABASE_PROVIDER=postgresql

# Exemplos PostgreSQL:
# Desenvolvimento local: postgresql://postgres:senha@localhost:5432/nossosaldo-dev?schema=public
# Homologacao:          postgresql://usuario:senha@host-hmg:5432/nossosaldo-hmg?schema=public
# Producao:             postgresql://usuario:senha@host-prod:5432/nossosaldo-prod?schema=public
#
# Exemplo MySQL:
# Desenvolvimento local: mysql://usuario:senha@localhost:3306/nossosaldo-dev
DATABASE_URL=

PORT=10000
JWT_EXPIRES=3600
APP_URL=http://localhost:10000
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/redefinir-senha
FRONTEND_EMAIL_VERIFICATION_URL=http://localhost:5173/validar-email
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=60
DEV_EMAIL_REDIRECT_TO=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REQUIRE_EMAIL_VERIFICATION=false
